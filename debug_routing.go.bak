package main

import (
	"context"
	"fmt"
	"github.com/dewitt/swarm/pkg/sdk"
	"os"
	"strings"
)

func main() {
	cwd, _ := os.Getwd()
	mem, _ := sdk.NewSemanticMemory(cwd)
	mem.Commit("IMPORTANT FACT: The project mascot is a neon-blue squirrel named 'Zap'.")

	s, _ := sdk.NewSwarm()
	prompt := "Who is the project mascot?"
	
	// Manually trigger Plan to see the routing prompt
	graph, _ := s.Plan(context.Background(), prompt, sdk.Trajectory{})
	fmt.Printf("Immediate Response: %s\n", graph.ImmediateResponse)
	if len(graph.Spans) > 0 {
		fmt.Printf("Delegated to: %s\n", graph.Spans[0].Agent)
	}
}
